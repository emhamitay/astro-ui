  <script define:vars={{ allComponentFiles }}>
    document.getElementById('download-all-btn')?.addEventListener('click', async () => {
      const JSZip = window.JSZip;
      const zip = new JSZip();
      for (const file of allComponentFiles) {
        zip.file('astro-ui/' + file.path, file.content);
      }
      const blob = await zip.generateAsync({ type: 'blob' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'astro-ui.zip';
      a.click();
      URL.revokeObjectURL(url);
    });
  </script>
  <script define:vars={{ componentsMd }}>
    document.getElementById('copy-components-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(componentsMd).then(() => {
        const label = document.getElementById('copy-components-label');
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy AI Context'; }, 1500);
        }
      });
    });
  </script>
  <script>
    const geistSnippet = `<!-- In your layout's <head> -->
<link href="https://cdn.jsdelivr.net/npm/@fontsource/geist-sans/400.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/@fontsource/geist-sans/500.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/@fontsource/geist-sans/600.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/@fontsource/geist-sans/700.css" rel="stylesheet" />

/* In your global CSS */
html { font-family: 'Geist Sans', system-ui, sans-serif; }`;
    document.getElementById('copy-geist-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(geistSnippet).then(() => {
        const label = document.getElementById('copy-geist-label');
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy font snippet'; }, 1500);
        }
      });
    });
  </script>
