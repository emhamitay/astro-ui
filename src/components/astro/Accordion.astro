---
interface AccordionItem {
  title: string;
  content: string;
  open?: boolean;
}

interface Props {
  items: AccordionItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<div class={`divide-y divide-border rounded-lg border ${className}`}>
  {items.map((item) => (
    <details open={item.open} class="group">
      <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-4 font-medium transition-colors hover:underline [&::-webkit-details-marker]:hidden">
        {item.title}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </summary>
      <div class="px-4 pb-4 pt-0 text-sm text-muted-foreground">
        {item.content}
      </div>
    </details>
  ))}
</div>
