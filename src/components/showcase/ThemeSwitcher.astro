---
const themes = [
  { id: 'zinc', label: 'Zinc', color: 'hsl(240 5.9% 10%)' },
  { id: 'slate', label: 'Slate', color: 'hsl(222 47% 11%)' },
  { id: 'blue', label: 'Blue', color: 'hsl(221 83% 53%)' },
  { id: 'green', label: 'Green', color: 'hsl(142 71% 45%)' },
  { id: 'rose', label: 'Rose', color: 'hsl(346 77% 50%)' },
  { id: 'orange', label: 'Orange', color: 'hsl(24 94% 50%)' },
];
---

<div class="flex flex-col gap-3">
  <div class="flex flex-wrap gap-2">
    {themes.map((t) => (
      <button
        class="theme-swatch flex items-center gap-2 rounded-lg border border-input px-3 py-1.5 text-xs font-medium transition-all hover:bg-accent hover:text-accent-foreground data-[active]:border-primary data-[active]:bg-primary/5"
        data-theme={t.id}
        aria-label={`Switch to ${t.label} theme`}
      >
        <span class="h-3 w-3 rounded-full border border-white/20 shadow-sm" style={`background:${t.color}`} />
        {t.label}
      </button>
    ))}
  </div>

  <div class="flex items-center gap-2">
    <button
      id="dark-mode-toggle"
      class="flex items-center gap-2 rounded-lg border border-input px-3 py-1.5 text-xs font-medium transition-all hover:bg-accent"
      aria-label="Toggle dark mode"
    >
      <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg id="moon-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      <span id="dark-mode-label">Dark mode</span>
    </button>

    <button
      id="download-css-btn"
      class="flex items-center gap-2 rounded-lg bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground transition-all hover:bg-primary/90"
      aria-label="Download CSS"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Download CSS
    </button>
  </div>
</div>

