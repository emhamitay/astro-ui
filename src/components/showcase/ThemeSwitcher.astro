let isDark = false;
let currentTheme = 'zinc';

function applyTheme(themeId: string, dark: boolean) {
  const theme = themeData[themeId];
  if (!theme) return;
  const root = document.documentElement;

  const lightVars = { ...theme };
  delete lightVars.dark;

  const darkVars = dark && theme.dark ? JSON.parse(theme.dark as string) : {};

  const vars = dark ? { ...lightVars, ...darkVars } : lightVars;

  for (const [key, val] of Object.entries(vars)) {
    if (key !== 'dark') root.style.setProperty(key, val as string);
  }

  root.classList.toggle('dark', dark);
}

function generateCSS(themeId: string): string {
  const theme = themeData[themeId];
  if (!theme) return '';
  const lightVars = { ...theme };
  delete lightVars.dark;
  const darkVars = theme.dark ? JSON.parse(theme.dark as string) : {};

  const lightLines = Object.entries(lightVars).map(([k, v]) => `    ${k}: ${v};`).join('\n');
  const darkLines = Object.entries(darkVars).map(([k, v]) => `    ${k}: ${v};`).join('\n');

  return `@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n@layer base {\n  :root {\n${lightLines}\n  }\n\n  .dark {\n${darkLines}\n  }\n}\n\n@layer base {\n  * {\n    @apply border-border;\n  }\n  body {\n    @apply bg-background text-foreground;\n  }\n}`;
}

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
    btn.addEventListener('click', () => {
      currentTheme = btn.dataset.theme ?? 'zinc';
      applyTheme(currentTheme, isDark);
      document.querySelectorAll('.theme-swatch').forEach((b) => b.removeAttribute('data-active'));
      btn.setAttribute('data-active', '');
    });
  });

  const firstBtn = document.querySelector<HTMLButtonElement>('.theme-swatch[data-theme="zinc"]');
  firstBtn?.setAttribute('data-active', '');

  const darkToggle = document.getElementById('dark-mode-toggle');
  const sunIcon = document.getElementById('sun-icon');
  const moonIcon = document.getElementById('moon-icon');
  const label = document.getElementById('dark-mode-label');

  darkToggle?.addEventListener('click', () => {
    isDark = !isDark;
    applyTheme(currentTheme, isDark);
    sunIcon?.classList.toggle('hidden', isDark);
    moonIcon?.classList.toggle('hidden', !isDark);
    if (label) label.textContent = isDark ? 'Light mode' : 'Dark mode';
  });

  document.getElementById('download-css-btn')?.addEventListener('click', () => {
    const css = generateCSS(currentTheme);
    const blob = new Blob([css], { type: 'text/css' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `shadcn-${currentTheme}-theme.css`;
    a.click();
    URL.revokeObjectURL(url);
  });
});
